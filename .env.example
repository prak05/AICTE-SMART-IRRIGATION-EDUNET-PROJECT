# AICTE Smart Irrigation System - Environment Variables
# Government of India Official Configuration

# OpenWeatherMap API Key (Primary)
# Get free key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# WeatherAPI Key (Backup)
# Get free key from: https://www.weatherapi.com/
WEATHERAPI_KEY=your_weatherapi_key_here

# Default City/District
DEFAULT_CITY=Thiruvananthapuram

# System Configuration
SYSTEM_MODE=Automatic (AI-Powered)
CACHE_DURATION=1800

# Government Settings
GOVT_ORG=AICTE
GOVT_DEPARTMENT=Ministry of Agriculture & Farmers Welfare
SYSTEM_VERSION=2.0.1

# Development Settings
DEBUG=False
LOG_LEVEL=INFO
